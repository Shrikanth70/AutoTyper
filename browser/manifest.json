{
    "manifest_version": 3,
    "name": "AutoTyper Pro",
    "version": "1.0",
    "description": "Reliable and state-safe auto-typing tool.",
    "permissions": [
        "clipboardRead",
        "activeTab"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "engine.js",
                "content.js"
            ]
        }
    ],
    "icons": {
        "128": "icon128.png"
    }
}